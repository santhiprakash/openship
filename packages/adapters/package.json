{
  "name": "@repo/adapters",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "embed:lua": "bun scripts/embed-lua.ts",
    "embed:catalog": "bun scripts/embed-catalog.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.668.0",
    "@aws-sdk/lib-storage": "^3.668.0",
    "@aws-sdk/s3-request-presigner": "^3.668.0",
    "@repo/core": "workspace:*",
    "dockerode": "^4.0.9",
    "ignore": "^7.0.5",
    "oblien": "^2.2.45",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.13.0",
    "@types/ssh2": "^1.15.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
