# Openship API - local SaaS development example
# Copy to .env.saas for local SaaS simulation. Do not commit real secrets.

NODE_ENV=development
PORT=4100

CLOUD_MODE=true
DEPLOY_MODE=cloud

DATABASE_URL=

BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:4100
TRUSTED_ORIGINS=http://localhost:3002,http://localhost:4100,http://localhost:3000
DASHBOARD_URL=http://localhost:3002

# In local SaaS mode, the "cloud" control plane is this local API/dashboard pair.
OPENSHIP_CLOUD_URL=http://localhost:4100
OPENSHIP_CLOUD_DASHBOARD_URL=http://localhost:3002

# Required for cloud deployments.
OBLIEN_CLIENT_ID=
OBLIEN_CLIENT_SECRET=

# Required for GitHub App mode.
GITHUB_APP_ID=
GITHUB_APP_SLUG=openship-io   # public slug at https://github.com/apps/<slug>; default in env.ts schema
GITHUB_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

SYSTEM_DEBUG_LOGS=false
