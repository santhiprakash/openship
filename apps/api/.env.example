# Openship API - Environment Variables
# Copy this file to .env and fill in the values.

NODE_ENV=development

# ---------- Mode ----------
# Set to "true" to enable cloud billing, metering, multi-tenant features.
# Default: false (self-hosted single-tenant mode).
CLOUD_MODE=false
# Runtime URL/port values live in packages/core/src/runtime-config.ts.

# ---------- Database ----------
DATABASE_URL=file:./dev.db

# ---------- Auth ----------
BETTER_AUTH_SECRET=change-me-in-production

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Stripe (Cloud mode only) ----------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ---------- GitHub App (for Git push webhooks) ----------
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=
# GITHUB_APP_SLUG=openship-io   # defaults to "openship-io"; only set when running your own App

OBLIEN_CLIENT_ID=oblien_your-client-id
OBLIEN_CLIENT_SECRET=sk_your-client-secret
