{
  "name": "@repo/desktop",
  "productName": "Openship",
  "version": "0.1.9",
  "private": true,
  "description": "Openship Desktop - Electron wrapper for the deployment dashboard",
  "author": "Oblien",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "rm -rf dist && tsc && node scripts/dev.mjs",
    "build": "node build/bundle.mjs",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "lint": "tsc --noEmit",
    "clean": "rm -rf out dist .turbo node_modules"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@reforged/maker-appimage": "^4.0.0",
    "@types/node": "^22.13.0",
    "electron": "40.8.0",
    "electronmon": "^2.0.4",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@repo/core": "workspace:*",
    "@repo/onboarding": "workspace:*"
  }
}
